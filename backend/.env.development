# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=password
DB_DATABASE=wechat_online_shop

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 应用配置
PORT=3000
NODE_ENV=development
JWT_SECRET=dev_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# 微信小程序配置（需要替换为实际的appid和secret）
WX_APPID=your_wechat_appid
WX_SECRET=your_wechat_secret